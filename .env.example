# =============================================================================
# DISCOVER MILWAUKEE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values
# These values are required for analytics and tracking

# Google Analytics 4 Measurement ID
# Get yours at: https://analytics.google.com/ -> Admin -> Data Streams -> Web
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Google Tag Manager Container ID (optional, use GA4 or GTM, not both)
# Get yours at: https://tagmanager.google.com/
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
